# 巨量引擎开放平台配置
OCEAN_ENGINE_APP_ID=YOUR_VALUE_HERE
OCEAN_ENGINE_SECRET=YOUR_VALUE_HERE

# 广告主ID (授权后会自动获取，也可手动填写)
OCEAN_ENGINE_ADVERTISER_ID=YOUR_VALUE_HERE

# 本地推账户ID (必填，用于调用本地推API)
OCEAN_ENGINE_LOCAL_ACCOUNT_ID=YOUR_VALUE_HERE

# 已有 Access Token (可选，如果已有token可以直接填写)
OCEAN_ENGINE_ACCESS_TOKEN=YOUR_VALUE_HERE

# 授权回调地址 (默认即可)
OCEAN_ENGINE_REDIRECT_URI=YOUR_VALUE_HERE

# 授权码 (通过 python main.py auth 获取授权链接后填入)
OCEAN_ENGINE_AUTH_CODE=YOUR_VALUE_HERE

# 告警推送
# 企业微信: 群聊 → 群机器人 → 添加 → 复制 Webhook 地址
WECOM_WEBHOOK_URL=YOUR_VALUE_HERE
# 飞书: 群聊 → 设置 → 群机器人 → 添加 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=YOUR_VALUE_HERE
