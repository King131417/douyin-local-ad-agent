# 巨量引擎开放平台配置
# 复制此文件为 .env 并填写真实值

# 应用凭证 (从 open.oceanengine.com 开发者后台获取)
OCEAN_ENGINE_APP_ID=your_app_id
OCEAN_ENGINE_SECRET=your_secret

# 广告主ID (从巨量引擎后台获取)
OCEAN_ENGINE_ADVERTISER_ID=your_advertiser_id

# 已有 Access Token (可选，如果已有token可以直接填写)
OCEAN_ENGINE_ACCESS_TOKEN=

# 告警推送 (可选)
WECOM_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
